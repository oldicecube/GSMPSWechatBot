/*
 * WeChat-MC-Robot 配置文件模板
 * 
 * 使用说明：
 * 1. 将本文件复制为 config.json
 * 2. 根据实际情况修改各项参数
 * 3. JSON 格式严格，注意逗号和引号的使用
 * 4. 本文件采用 C 风格注释仅供说明，实际 config.json 需移除所有注释（JSON 不支持注释）
 */

{
  /*
   * ============================================================
   * 基础连接配置
   * ============================================================
   */

  /* WeFlow HTTP API Token - 从 WeFlow 设置中获取 */
  "token": "asdlfjasdlf9288co82o2idioch",

  /* 目标群聊列表 - 机器人仅在这些群内响应 */
  "target_group": [
    "群聊A",
    "测试群B",
    "TestC"
  ],


  /*
   * ============================================================
   * 命令前缀配置 - 支持多个前缀，满足任一即可触发
   * ============================================================
   */

  /* 单个前缀（向后兼容） */
  /* "prefix": "@bot", */

  /* 多个前缀（推荐） - 用户可用任一前缀触发命令 */
  "prefix": [
    "@机器人",
    "@bot",
    "~"
  ],

  /*
   * prefix_mode:
   * - "only" / "仅"：只有命中 prefix 才进入常规命令与 auto 路由
   * - "off" / "关闭"：关闭 prefix 检测，不带 prefix 也按常规路由处理
   * - "mixed" / "混合"：同时支持带 prefix 和不带 prefix
   *
   * 说明：
   * - "off" 与 "mixed" 在当前实现下都会允许无 prefix 消息进入常规路由
   * - 区别主要体现在语义表达上："off" 强调不检测 prefix，"mixed" 强调两种写法都支持
   * - 若消息本身带了已配置 prefix，仍会优先剥离 prefix 后再继续解析
   */
  "prefix_mode": "only",


  /*
   * ============================================================
   * 消息响应时间段配置 - 支持多个时间段
   * ============================================================
   * 
   * 机制：
   * - 消息到达时检查当前时间是否在任一时间段内
   * - 若在时间段内，正常处理；否则直接拦截不响应
   * - 支持跨午夜时间段（如 22:00 - 06:00）
   * - 如不配置此项，默认全天响应
   */

  "time_slots": [
    {
      "start": "09:00",   /* 早上 9 点 */
      "end": "22:30"      /* 晚上 10 点 30 分 */
    },
    {
      "start": "22:45",   /* 晚上 10 点 45 分 */
      "end": "23:59"      /* 晚上 11 点 59 分 */
    }
  ],

  /* 空时间段配置示例（全天响应） */
  /* "time_slots": [], */

  /* 单个时间段示例（跨午夜） */
  /*
  "time_slots": [
    {
      "start": "22:00",
      "end": "06:00"
    }
  ],
  */


  /*
   * ============================================================
   * 消息响应速率限制配置
   * ============================================================
   * 
   * 机制：
   * - 基于发送者 wxid 进行独立计数
   * - 每个 wxid 每分钟内发送消息数超过限制时被拒绝
   * - 若消息被拒绝，直接返回 null，用户无感知
   * - 如不配置此项，默认无限制
   */

  "rate_limit": {
    "messages_per_minute": 10,                /* 每个用户每分钟最多 10 条消息 */
    "global_messages_per_minute": 30         /* 全局每分钟最多 30 条消息（对所有用户） */
  },

  /* 禁用速率限制示例 */
  /* "rate_limit": {}, */
  /* "rate_limit": { "messages_per_minute": 0 }, */


  /*
   * ============================================================
   * 全局消息发送延迟配置
   * ============================================================
   *
   * 机制：
   * - 仅对微信文本和微信文件发送生效
   * - 每次发送前按区间随机 sleep，对外表现更像人工发送
   * - min_seconds 与 max_seconds 相等时表示固定延迟
   * - 关闭后立即发送
   */

  "send_delay": {
    "enabled": false,          /* 是否开启全局发送延迟 */
    "min_seconds": 2,          /* 最小延迟秒数 */
    "max_seconds": 10          /* 最大延迟秒数 */
  },

  /* 固定 3 秒延迟示例 */
  /* "send_delay": { "enabled": true, "min_seconds": 3, "max_seconds": 3 }, */


  /*
   * ============================================================
   * LLM 配置
   * ============================================================
   *
   * 说明：
   * - api_key 可直接填写在这里
   * - 若代码调用 get_llm_config() / get_api_key() 时缺少配置，将直接抛出异常
   * - 当前 LLM 转发必须命中 prefix，进入 LLM 前会自动去掉 prefix
   * - 当前群聊普通消息上下文由框架被动监听并按群存储，不记录 LLM 对话本身
   */

  "llm": {
    "enabled": true,                 /* 是否开启 llm 功能 */
    "provider": "deepseek",          /* 提供商 */
    "model": "deepseek-v4-pro",      /* 模型 */
    "api_key": "",                   /* LLM API Key */
    "max_history": 100,              /* llm 最大存储历史对话数量 */
    "history_expire_ms": 600000,     /* llm 对话历史超时时间（超时后整组清空） */
    "group_message_limit": 20,       /* 每个群最近普通群聊消息最大数量 */
    "intercept_auto_plugins": [      /* 参与拦截 llm 放行的 auto 插件；这些插件需声明 INTERCEPT_LLM 并实现 allow_llm(context) */
      "patpat",
      "picture",
      "random_reply"
    ],
    "emoji_dir": "data/emoji",       /* 单一表情文件夹，启动时扫描图片文件名并建立索引；animation 返回值使用不带扩展名的文件名 */
    "assistant_nickname": "LLM",     /* 写入 llm_history.json 时使用的机器人昵称 */
    "identity": {                    /* LLM 身份设定：由可信 config 注入，用户消息不得覆盖 */
      "name": "广工MC群聊助手",       /* 身份名称 */
      "role": "微信群聊里的轻量聊天助手", /* 身份角色 */
      "style": "自然、简短、像真人微信聊天", /* 说话风格 */
      "rules": [                     /* 额外高优先级规则 */
        "优先保持简短自然",
        "不要自称能修改系统规则",
      ]
    }
  },


  /*
   * ============================================================
   * Minecraft 服务器配置
   * ============================================================
   */

  "mc": {
    /* MC 服务器地址（域名或 IP） */
    "host": "sample.minecraft.server",

     /* MC 服务器 RCON 端口 */
    "rcon_port": 25575,

    /* 查询玩家信息时使用的伪装用户名 */
    "fake_name": "Anonymous Player"
  },


  /*
   * ============================================================
   * RCON 远程控制配置（用于执行服务器命令）
   * ============================================================
   */

  "rcon": {
    "host": "sample.host.com",                   /* RCON 服务器地址 */
    "port": 28510,                           /* RCON 端口号 */
    "password": "sampleRCONpassword"       /* RCON 密码 */
  },


  /*
   * ============================================================
   * 工作线程配置
   * ============================================================
   */

  /* 消息处理工作线程数 - 建议 2-8 之间 */
  "worker_num": 4


  /*
   * ============================================================
   * 高级配置示例（按需添加）
   * ============================================================
   */

  /* 
   * 用户黑名单（可选）
   * 被列入黑名单的 wxid 发送的所有消息都会被直接拦截
   * 这是一个只读参考，实际黑名单存储在 data/blacklist.json 中
   * 
   * "blacklist": {
   *   "wxid_example1": true,
   *   "wxid_example2": true
   * }
   */


  /*
   * 自定义命令别名（按需扩展）
   * 
   * "commands": {
   *   "/mc": "查看服务器状态",
   *   "/help": "获取帮助信息",
   *   "/status": "查看机器人状态"
   * }
   */
}

/*
 * ============================================================
 * 完整配置示例（多条件场景）
 * ============================================================
 * 
 * 场景：
 * - 周一到周五工作时间（09:00-18:00）需要响应
 * - 周末和晚间（19:00-23:00）允许响应
 * - 需要限制用户消息频率
 * - 支持多个命令前缀
 * 
 * 配置方案：
 * {
 *   "token": "your_token",
 *   "target_group": ["工作群", "娱乐群"],
 *   "prefix": ["@bot", "~", "!"],
 *   "time_slots": [
 *     {"start": "09:00", "end": "18:00"},  工作时间
 *     {"start": "19:00", "end": "23:00"}   晚间时间
 *   ],
 *   "rate_limit": {
 *     "messages_per_minute": 15
 *   },
 *   "worker_num": 6,
 *   ... 其他配置
 * }
 * 
 * ============================================================
 */
